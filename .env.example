# Binance (public endpoints need no key, but Pro key unlocks higher limits)
BINANCE_API_KEY=
BINANCE_SECRET=

# CoinGecko Pro (optional - free tier has lower rate limits)
COINGECKO_API_KEY=

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# App
ENVIRONMENT=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://cryp2me.ai
